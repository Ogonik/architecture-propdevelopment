        <mxCell id="KRUFYhosnbqbZD0XPdTP-1883" value="Искажение/порча онлайн тура может повлиять на репутацию компании" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
