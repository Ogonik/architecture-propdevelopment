        <mxCell id="1778" value="&lt;div&gt;Данные о доступном фонде недвижимости компании&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=default;strokeWidth=1;fillColor=#61c6ce;fontFamily=Helvetica;fontSize=14;fontColor=default;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
