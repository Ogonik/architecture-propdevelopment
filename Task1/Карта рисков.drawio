        <mxCell id="KRUFYhosnbqbZD0XPdTP-1779" value="Утечка&lt;div&gt;К1&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontSize=14;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;shadow=0;labelBackgroundColor=none;strokeWidth=3;spacing=5;arcSize=7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="-480" y="-410" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1781" value="Потеря&lt;br&gt;K2" style="whiteSpace=wrap;html=1;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;shadow=0;labelBackgroundColor=none;strokeWidth=3;spacing=5;arcSize=7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="-320" y="-410" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1783" value="Искажение&lt;div&gt;K3&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontSize=14;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;shadow=0;labelBackgroundColor=none;strokeWidth=3;spacing=5;arcSize=7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="-410" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1787" value="&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;K1&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;Компания входит в топ строительных компаний --&amp;gt; обладает широкой аудиторией и большим количеством данных, поэтому привлекает внимание хакеров и охотников за персональными и иными корпоративными данными. Также, поскольку речь идет о достаточно весомых финансовых транзакциях, которые недоступны 80-90% населения нашей страны, то среди клиентов могут попасться люди с высоким социальным статусом (VIP клиенты), что дополнительно привлекает внимание охотников за данными (персоналньыми и транзакционными)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="-1920" y="-700" width="380" height="210" as="geometry" />
        </mxCell>
