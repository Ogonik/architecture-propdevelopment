        <mxCell id="KRUFYhosnbqbZD0XPdTP-1869" style="edgeStyle=none;shape=connector;rounded=0;jumpStyle=none;orthogonalLoop=1;jettySize=auto;html=1;shadow=0;strokeColor=default;strokeWidth=1;align=center;verticalAlign=middle;spacing=5;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;startArrow=none;startFill=0;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="KRUFYhosnbqbZD0XPdTP-1860" target="KRUFYhosnbqbZD0XPdTP-1856">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1860" value="Риск потери данных данной категории может привести к временному ограничению маркетинговой активности и, возможно, приостановить ведение сделок купли-продажи, однако потерянные даныне могут достаточно легко восстановлены из фактически построенных/строящихся объектов и их документации" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="2300" y="-150" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1867" style="edgeStyle=none;shape=connector;rounded=0;jumpStyle=none;orthogonalLoop=1;jettySize=auto;html=1;shadow=0;strokeColor=default;strokeWidth=1;align=center;verticalAlign=middle;spacing=5;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;startArrow=none;startFill=0;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="KRUFYhosnbqbZD0XPdTP-1861" target="KRUFYhosnbqbZD0XPdTP-1855">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="KRUFYhosnbqbZD0XPdTP-1868" style="edgeStyle=none;shape=connector;rounded=0;jumpStyle=none;orthogonalLoop=1;jettySize=auto;html=1;shadow=0;strokeColor=default;strokeWidth=1;align=center;verticalAlign=middle;spacing=5;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;startArrow=none;startFill=0;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="KRUFYhosnbqbZD0XPdTP-1861" target="KRUFYhosnbqbZD0XPdTP-1857">
